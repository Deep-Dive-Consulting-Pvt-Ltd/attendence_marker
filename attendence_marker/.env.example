# MongoDB Atlas
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/<db-name>?retryWrites=true&w=majority
MONGODB_DATABASE=attendance_db
MONGODB_CONNECT_TIMEOUT_MS=15000

# App
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=false
CORS_ORIGINS=*

# Storage
DATA_DIR=data
FACES_DIR=data/faces
ATTENDANCE_CROPS_DIR=data/attendance_crops
TEMP_DIR=temp_uploads

# Attendance defaults
DEFAULT_THRESHOLD=0.3
DEFAULT_SESSION=2025-26
